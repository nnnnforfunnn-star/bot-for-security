# Токен Telegram Бота, полученный от @BotFather (Обязательно)
BOT_TOKEN=1234567890:ABCdefGhIJKlmNoPQRsTUVwxyZ

# Секретный токен для верификации запросов вебхука от Telegram (Необязательно, но рекомендуется для продакшена)
WEBHOOK_SECRET=your_secure_webhook_secret_here

# Среда выполнения (development / production)
NODE_ENV=development
